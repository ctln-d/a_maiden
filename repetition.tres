// Texture2D:11
	vec4 n_out11p0 = texture(tex_frg_11, UV);


// Mix:10
	vec3 n_out10p0 = mix(vec3(n_out2p0.xyz), vec3(n_out6p0.xyz), vec3(n_out11p0.xyz));


// Output:0
	ALBEDO = n_out10p0;


}
